44    8034 01 4B 00       ld bc, printhex-start ; stop searching at beginning
45    8037 3E 00          ld a,0
46    8039 ED B9          cpdr ; now search backwards
47    803B 23             inc hl; as hl will overshoot this time in the other direction
48    803C 7C             ld a,h
49    803D CD 4B 80       call printhex
50    8040 7D             ld a,l
51    8041 CD 4B 80       call printhex
52    8044 3E 0D          ld a,ENTER
53    8046 D7             rst $10
54    8047
55    8047 00             nop ; the second nop to search for
56    8048
57    8048 E1             pop hl
58    8049 D9             exx ; restore hl' to gracefully return to BASIC
59    804A C9             ret
60    804B
61    804B              printhex: ; print A as hex byte
62    804B F5             push af ; save full byte on stack
63    804C CB 3F          srl a
64    804E CB 3F          srl a
65    8050 CB 3F          srl a
66    8052 CB 3F          srl a; move upper nybble to lower spot
67    8054 CD 5E 80       call printhex_digit
68    8057 F1             pop af
69    8058 E6 0F          and $0F
70    805A CD 5E 80       call printhex_digit
