 1    0000                DEVICE ZXSPECTRUM48
 2    0000
 3    0000                org $8000
 4    8000
 5    8000              ENTER   = $0D
 6    8000
 7    8000              start:
 8    8000 D9             exx
 9    8001 E5             push hl ; preserve HL'
10    8002
11    8002 00             nop ; do nothing!
12    8003
13    8003 21 57 36       ld hl,$3657 ; load 3657 into HL as BCD
14    8006 01 45 28       ld bc,$2845 ; load 2845 into HL as BCD
15    8009 7D             ld a, l
16    800A 81             add a, c ; add units and tens
17    800B 27             daa ; do bcd adjustment
18    800C 6F             ld l, a ; put answer back in l
19    800D 7C             ld a, h
