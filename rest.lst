21    800F 27             daa ; do bcd adjustment
22    8010 67             ld h, a ; put answer back into h (HL = HL + BC (BCD))
23    8011 CD 4B 80       call printhex ; print decimal digits in H (thousands, hundreds)
24    8014 7D             ld a, l
25    8015 CD 4B 80       call printhex; print decimal digits in L (tens, units)
26    8018 3E 0D          ld a,ENTER
27    801A D7             rst $10; print newline
28    801B
29    801B                ; find the first NOP in main routine
30    801B 21 00 80       ld hl,start
31    801E 01 4B 00       ld bc,printhex-start  ; stop searching after end of routine code
32    8021 3E 00          ld a,0 ; a = NOP code
33    8023 ED B1          cpir
34    8025 2B             dec hl ; because of overshoot when you run cpir
35    8026 7C             ld a,h ; upper byte of first NOP
36    8027 CD 4B 80       call printhex ;
37    802A 7D             ld a,l ; lower byte of first NOP
38    802B CD 4B 80       call printhex;
39    802E 3E 0D          ld a,ENTER
40    8030 D7             rst $10
41    8031
42    8031                ; find the first NOP in the main routine
