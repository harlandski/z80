 12   4000              SEED 	  = $04 ; The non-zero seed needs to be in RAM, and can be entered after 00 C3 00 40
 13   4000
 14   4000 3A 04 00     RANDOM: ld a, (SEED)
 15   4003 47                   ld b,a
 16   4004
 17   4004 0F                   rrca
