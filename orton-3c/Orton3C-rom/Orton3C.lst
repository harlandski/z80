 25   400C 32 04 00             ld (SEED), a; save number as next seed, and also for use in CONV
 26   400F
 27   400F              ; read the input, and deal with edge cases of $00 and $FF
 28   400F DB 00        INPUT:  in A,($00)
 29   4011 FE 00                cp $00
 30   4013 28 43                jr z, OUTPUT
 31   4015 FE FF                cp $FF
 32   4017 28 04                jr z, IS255
 33   4019 47                   ld b,a ; b is the maximum we want
 34   401A 04                   inc b; but we need to test one more than max
 35   401B 18 01                jr TESTS
 36   401D 47           IS255:  ld b,a; unless a is 255, then we'll leave it as that
 37   401E
 38   401E              ; test bits and set mask. Only the highest mask remains
 39   401E 0E 00        TESTS:  ld c,0; reset mask
 40   4020 CB 47        TEST0:  bit 0,a ; is bit 0 set?
 41   4022 28 02                jr z, TEST1
 42   4024 0E 01                ld c,%00000001; mask
 43   4026 CB 4F        TEST1:  bit 1,a; is bit 1 set?
 44   4028 28 02                jr z, TEST2
 45   402A 0E 03                ld c,%00000011
 46   402C CB 57        TEST2:  bit 2,a; is bit 2 set?
 47   402E 28 02                jr z, TEST3
 48   4030 0E 07                ld c,%00000111
 49   4032 CB 5F        TEST3:  bit 3,a ; etc
 50   4034 28 02                jr z, TEST4
 51   4036 0E 0F                ld c,%00001111
 52   4038 CB 67        TEST4:  bit 4,a
 53   403A 28 02                jr z, TEST5
 54   403C 0E 1F                ld c,%00011111
 55   403E CB 6F        TEST5:  bit 5,a
 56   4040 28 02                jr z, TEST6
 57   4042 0E 3F                ld c,%00111111
 58   4044 CB 77        TEST6:  bit 6,a
 59   4046 28 02                jr z, TEST7
 60   4048 0E 7F                ld c,%01111111
 61   404A CB 7F        TEST7:  bit 7,a
 62   404C 28 02                jr z, CONV
 63   404E 0E FF                ld c,%11111111
 64   4050
 65   4050              ; Convert to range 1-max, and truncate numbers higher than desired
 66   4050 3A 04 00     CONV:   ld a, (SEED) ; bring our random number back
 67   4053 A1                   and c   ; keep lowest bits as per mask
 68   4054 3C                   inc a   ; make range start at 1
 69   4055 B8                   cp b    ; if result is > max
 70   4056 30 A8                jr nc,RANDOM     ; reject and start again
 71   4058
 72   4058 D3 00        OUTPUT: out ($00),a ; infinite loop
 73   405A 18 FC                jr OUTPUT
