# file opened: romtype.asm
 1    0000                DEVICE ZXSPECTRUM48
 2    0000
 3    0000                org $8000
 4    8000
 5    8000              ; Routines
 6    8000              CL_ALL      = $0DAF
 7    8000              KEY_INPUT   = $10A8
 8    8000
 9    8000              ; Character codes
10    8000              SPACE       = $20
11    8000              COPYRIGHT   = $7F
12    8000
13    8000              ; Control codes
14    8000              ENTER       = $0D
15    8000              INK         = $10
16    8000              AT          = $AC
17    8000
18    8000              start:
19    8000 ED 56          im 1            ; Use ROM-based interrupt routine
20    8002 FB             ei              ; Enable maskable interrupts
21    8003 CD AF 0D       call CL_ALL
22    8006              key_loop:
23    8006 CD A8 10       call KEY_INPUT  ; get last key pressed
24    8009 D2 06 80       jp nc,key_loop  ; if C is clear, keep waiting for key press. This is because the ROM routine puts the key value in A, but also sets the carry flag
25    800C FE AC          cp AT           ; Symbol shift + i has been pressed
26    800E CA 23 80       jp z,do_ink     ; If Symbol shift + i has been pressed, jump to do_ink
27    8011 FE 0D          cp ENTER        ; Check to see if enter code has been pressed
28    8013 CA 3D 80       jp z, print     ; If so, print it
29    8016 FE 20          cp SPACE;
30    8018 FA 06 80       jp m,key_loop   ; If code < space character, ignore
31    801B FE 80          cp COPYRIGHT+1
32    801D F2 06 80       jp p,key_loop   ; If code > copyright character, ignore
33    8020 C3 3D 80       jp print
34    8023              do_ink:
35    8023 3E 10          ld a,INK
36    8025 D7             rst $10         ; "Print" ink Character
37    8026              ink_loop:
38    8026 CD A8 10       call KEY_INPUT
39    8029 D2 26 80       jp nc,ink_loop ; wait for another key press
40    802C FE 30          cp $30
41    802E FA 3B 80       jp m,reset_ink ; if code is < "0", reset ink colour
42    8031 FE 38          cp $38
43    8033 F2 3B 80       jp p,reset_ink ; if code >= '8', reset ink color
44    8036 D6 30          sub $30        ; get numerical value of numeral character
45    8038 C3 3D 80       jp print       ; and "print" it as an ink value
46    803B              reset_ink:
47    803B 3E 00          ld a,0         ; reset ink to black
48    803D              print:
49    803D D7             rst $10        ; print whatever needs printing (character, ink code)
50    803E C3 06 80       jp key_loop    ; loop infinitely
51    8041
52    8041                SAVESNA "romtype.sna", start
53    8041
# file closed: romtype.asm
