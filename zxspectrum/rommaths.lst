# file opened: rommaths.asm
 1    0000                DEVICE ZXSPECTRUM48
 2    0000
 3    0000                org $8000
 4    8000
 5    8000              start:
 6    8000 F3             di
 7    8001 31 00 5B       ld sp,$5B00 ; normal stack area
 8    8004 FD 21 3A 5C    ld iy,$5C3A ; system variables base
 9    8008 FB             ei
10    8009
11    8009 CD 85 17       call $1785 ; OPEN-S: select screen channel
12    800C
13    800C 21 15 80       ld hl,calcprog ; HL points to calculator program
14    800F EF             rst $28 ; run calculator
15    8010
16    8010                ; now the result is on the calculator stack
17    8010 CD E3 2D       call $2DE3 ; ROM: PRINT_FP (prints top of FP stack)
18    8013
19    8013              hang:
20    8013 18 FE          jr hang ;
21    8015
22    8015              calcprog:
23    8015 0E 02          defb $0E,2 ; literal integer 2
24    8017 0E 02          defb $0E,2 ; literal integer 2
25    8019 38             defb $38 ; add and exit
26    801A
27    801A                SAVESNA 'rommaths.sna',start
28    801A
# file closed: rommaths.asm
