# file opened: beep.asm
 1    0000                DEVICE ZXSPECTRUM48
 2    0000
 3    0000                org $8000
 4    8000
 5    8000              start:
 6    8000 01 FE FE       ld bc,$FEFE ; in - keyboard SHIFT,ZXCV out: beeper
 7    8003 16 00          ld d,0 ; D = byte to output - toggled for beeper frequency
 8    8005              .keyloop:
 9    8005 ED 78          in a,(c) ; A = key states
10    8007 CB 57          bit 2,a  ; Check bit 2 (X key)
11    8009 C2 13 80       jp nz,.soundoff ; note the keystates are 1 by default, 0 if pressed
12    800C 7A             ld a,d   ; A = last output byte
13    800D EE 10          xor $10  ; flip bit 4
14    800F 57             ld d,a   ; save new byte back to D
15    8010 C3 15 80       jp .output
16    8013              .soundoff:
17    8013 3E 00          ld a,0  ; hold output to zero
18    8015              .output:
19    8015 ED 79          out (c), a ; output determined byte value
20    8017 00          > nop ; a load of NOPs - kind of impractical if you are going to enter this by hand
20    8018 00          > nop
20    8019 00          > nop
